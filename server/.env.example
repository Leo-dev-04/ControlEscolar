# ═══════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SERVIDOR
# ═══════════════════════════════════════════════════════════

# Puerto del servidor (default: 3000)
PORT=3000

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# Nivel de logging (error | warn | info | debug)
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS (MySQL)
# ═══════════════════════════════════════════════════════════

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=control_escolar_db

# ═══════════════════════════════════════════════════════════
# SEGURIDAD Y AUTENTICACIÓN
# ═══════════════════════════════════════════════════════════

# Secret para JWT (IMPORTANTE: Debe tener mínimo 32 caracteres)
# Genera uno random con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu_jwt_secret_muy_seguro_de_minimo_32_caracteres_aqui

# Tiempo de expiración del token JWT (ejemplos: 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# ═══════════════════════════════════════════════════════════
# FRONTEND
# ═══════════════════════════════════════════════════════════

# URL del frontend para CORS
FRONTEND_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════
# EMAIL (SMTP)
# ═══════════════════════════════════════════════════════════

# Configuración SMTP para envío de reportes
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com

# Para Gmail, usar App Password (no la contraseña normal)
# Generar en: https://myaccount.google.com/apppasswords
SMTP_PASS=tu_app_password_de_gmail

# Nombre que aparecerá como remitente
SCHOOL_NAME=Control Escolar Primaria

# Delay entre envío de emails (milisegundos)
EMAIL_DELAY_MS=1000

# ═══════════════════════════════════════════════════════════
# CRON JOBS (Tareas Programadas)
# ═══════════════════════════════════════════════════════════

# Habilitar envío automático de reportes (true | false)
AUTO_SEND_ENABLED=false

# Programación de cron para reportes semanales
# Formato: 'minuto hora dia mes dia_semana'
# Default: '0 18 * * 5' = Viernes a las 6:00 PM
CRON_REPORTE=0 18 * * 5

# ═══════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ═══════════════════════════════════════════════════════════

# 1. Copia este archivo como .env en la raíz del proyecto
# 2. NUNCA subas el archivo .env a Git (está en .gitignore)
# 3. JWT_SECRET debe ser único y muy seguro en producción
# 4. Para Gmail, habilita "Acceso de aplicaciones menos seguras" o usa App Passwords
# 5. En producción, usa variables de entorno del servidor (no archivo .env)
